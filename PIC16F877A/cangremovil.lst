                      00001 ;Definimos los pines de salida del sistema
                      00002 
                      00003 ;   QTR 8A      PIC16F877A      CHANNEL
                      00004 ;   PIN D1      PIN RA0           AN0 (Sensor S7 - Izquierdo)
                      00005 ;   PIN D2      PIN RA1           AN1
                      00006 ;   PIN D3      PIN RA2           AN2
                      00007 ;   PIN D4      PIN RA3           AN3
                      00008 ;   PIN D5      PIN RA5           AN4
                      00009 ;   PIN D6      PIN RE0           AN5
                      00010 ;   PIN D7      PIN RE1           AN6
                      00011 ;   PIN D8      PIN RE2           AN7 (Sensor S0 - Derecho)
                      00012 ;   PIN IR      VCC 5V
                      00013 
                      00014 ;============Modulos PWM para motores a driver========
                      00015 ;   PWM     PIC16F877A      DRIVER TB6612FNG
                      00016 ;   CCP1       RC2          PWMB (Motor Derecho)
                      00017 ;   CCP2       RC1          PWMA (Motor Izquierdo)
                      00018 
                      00019 ;============Modulos de logica de los motores===================
                      00020 ;   PIC16F877A      DRIVER TB6612FNG
                      00021 ;   PIN RD0             AIN1 (Dir Motor Izquierdo)
                      00022 ;   PIN RD1             AIN2 (Dir Motor Izquierdo)
                      00023 ;   PIN RD2             BIN1 (Dir Motor Derecho)
                      00024 ;   PIN RD3             BIN2 (Dir Motor Derecho)
