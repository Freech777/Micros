000138 2235           00397     ADDWFC Suma_Izq_H, F
                      00398 
                      00399 ; ==========================================
                      00400     ; LA RESTA FINAL: Error = Suma_Der - Suma_Izq
                      00401     ; ==========================================
00013A 5034           00402     MOVF Suma_Izq_L, W
00013C 5C32           00403     SUBWF Suma_Der_L, W     ; Resta partes bajas (Suma_Der_L - Suma_Izq_L). Guarda en W
00013E 6E24           00404     MOVWF Error_L           ; Guarda en tu variable Error_L
                      00405     
000140 5035           00406     MOVF Suma_Izq_H, W
000142 5833           00407     SUBWFB Suma_Der_H, W    ; Resta partes altas CON BORROW (Préstamo). Guarda en W
000144 6E25           00408     MOVWF Error_H           ; Guarda en tu variable Error_H
000146 0012           00409     RETURN
