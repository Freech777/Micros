00028C                00747 LEER_CANAL_ADC
                      00748     ; 1. Seleccionar el canal y encender el módulo ADC
00028C 6EC2           00749     MOVWF ADCON0        
                      00750 
                      00751     ; 2. Iniciar la conversión (Poner el bit GO/DONE en 1)
00028E 82C2           00752     BSF ADCON0, GO_DONE 
                      00753 
000290                00754 ESPERAR_ADC
