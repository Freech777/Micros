                      00411 ; =========================================================================
                      00412 ; SUBRUTINA: CALCULAR_PROPORCIONAL
MPASM  5.39                           PID.ASM   5-31-2026  18:34:27         PAGE  9


LOC  OBJECT CODE     LINE SOURCE TEXT
  VALUE

                      00413 ; Propósito: Multiplica Error (16 bits con signo) * Kp (8 bits sin signo)
                      00414 ; =========================================================================
000148                00415 CALCULAR_PROPORCIONAL
                      00416 ; ---------------------------------------------------------------------
                      00417     ; FASE 1: EXTRACCIÓN DEL SIGNO Y CONVERSIÓN A VALOR ABSOLUTO
                      00418     ; ---------------------------------------------------------------------
000148 9038           00419     BCF Banderas, 0         ; Asumimos por defecto que el Error es Positivo (Bit = 0)
00014A AE25           00420     BTFSS Error_H, 7        ; Revisamos el bit 7 (Bit de Signo) de la parte alta
00014C D007           00421     BRA FASE_2_MULTIPLICAR  ; Si es 0 (positivo), saltamos directo a multiplicar
                      00422 
                      00423     ; Si el programa no saltó, significa que el Error es NEGATIVO.
00014E 8038           00424     BSF Banderas, 0         ; Levantamos la bandera: ¡Hay que corregir hacia la Izquierda! (Bit = 1)
                      00425     
                      00426     ; Convertimos el número negativo a positivo (Operación de Complemento a 2)
                      00427     ; Matemáticamente es: Invertir todos los bits y sumar 1.
000150 1E24           00428     COMF Error_L, F         ; Invertir bits de la parte baja
000152 1E25           00429     COMF Error_H, F         ; Invertir bits de la parte alta
                      00430     
000154 0E01           00431     MOVLW 1
000156 2624           00432     ADDWF Error_L, F        ; Sumamos 1 a la parte baja
000158 0E00           00433     MOVLW 0
00015A 2225           00434     ADDWFC Error_H, F       ; Sumamos el acarreo (Carry) a la parte alta si lo hubo
                      00435 
00015C                00436 FASE_2_MULTIPLICAR
                      00437     ; A partir de este punto, Error_H : Error_L es un valor POSITIVO absoluto.
                      00438     ; La dirección a girar está a salvo guardada en "Banderas, 0".
                      00439 
                      00440     ; ---------------------------------------------------------------------
                      00441     ; FASE 2: MULTIPLICACIÓN 16x8 BITS USANDO HARDWARE (MULWF)
                      00442     ; ---------------------------------------------------------------------
                      00443     
                      00444     ; PASO A: Multiplicar la Parte Baja (Error_L * Kp)
00015C 5037           00445     MOVF Kp, W              ; Cargar la constante/variable Kp en W
00015E 0224           00446     MULWF Error_L           ; Multiplicar. El resultado de 16 bits cae en PRODH:PRODL
                      00447     
                      00448     ; Guardamos este primer resultado
000160 CFF3 F039      00449     MOVFF PRODL, Termino_P_L ; La parte baja de P ya está lista
000164 CFF4 F03A      00450     MOVFF PRODH, Termino_P_H ; Guardamos temporalmente el acarreo en la parte alta de P
                      00451 
                      00452     ; PASO B: Multiplicar la Parte Alta (Error_H * Kp)
000168 5037           00453     MOVF Kp, W
00016A 0225           00454     MULWF Error_H           ; Multiplicar. Resultado cae nuevamente en PRODH:PRODL
                      00455     
                      00456     ; Acomodo matemático cruzado:
                      00457     ; La parte baja de este nuevo resultado (PRODL) tiene el "peso" de la parte alta.
                      00458     ; Por lo tanto, se la sumamos a la parte alta que guardamos en el Paso A.
00016C 50F3           00459     MOVF PRODL, W
00016E 263A           00460     ADDWF Termino_P_H, F    ; Sumar al registro final Termino_P_H
                      00461     
                      00462     ; (Nota: Ignoramos PRODH de esta segunda multiplicación. Asumimos que 
                      00463     ;  tu Kp estará escalado para que el resultado de 'P' no exceda los 16 bits,
                      00464     ;  que es el límite natural para los módulos PWM de los motores).
                      00465 
MPASM  5.39                           PID.ASM   5-31-2026  18:34:27         PAGE 10


LOC  OBJECT CODE     LINE SOURCE TEXT
  VALUE

000170 0012           00466     RETURN                  ; Regresamos al lazo PID principal
                      00467 
000172                00468 CALCULAR_DERIVATIVO
                      00469     ; ---------------------------------------------------------------------
                      00470     ; FASE 1: LA RESTA (Delta Error = Error Actual - Error Anterior)
                      00471     ; ---------------------------------------------------------------------
                      00472     ; Restamos las partes bajas (Error_L - Error_Anterior_L)
000172 5026           00473     MOVF Error_Anterior_L, W
000174 5C24           00474     SUBWF Error_L, W
000176 6E3C           00475     MOVWF Delta_Error_L
                      00476 
                      00477     ; Restamos las partes altas CON PRÉSTAMO (Borrow)
000178 5027           00478     MOVF Error_Anterior_H, W
00017A 5825           00479     SUBWFB Error_H, W
00017C 6E3D           00480     MOVWF Delta_Error_H
                      00481 
                      00482     ; ---------------------------------------------------------------------
                      00483     ; FASE 2: EXTRACCIÓN DEL SIGNO (El sentido del freno)
                      00484     ; ---------------------------------------------------------------------
00017E 9238           00485     BCF Banderas, 1         ; Asumimos que Delta_Error es positivo (Bit 1 = 0)
000180 AE3D           00486     BTFSS Delta_Error_H, 7  ; Revisamos el bit de signo
000182 D007           00487     BRA FASE_3_MULTIPLICAR_D ; Si es 0 (positivo), saltamos directo a multiplicar
                      00488 
                      00489     ; Si es negativo, levantamos la bandera (Bit 1 = 1)
000184 8238           00490     BSF Banderas, 1         
                      00491     
                      00492     ; Convertimos Delta_Error a positivo (Complemento a 2) para poder multiplicarlo
000186 1E3C           00493     COMF Delta_Error_L, F   
000188 1E3D           00494     COMF Delta_Error_H, F   
00018A 0E01           00495     MOVLW 1
00018C 263C           00496     ADDWF Delta_Error_L, F  
00018E 0E00           00497     MOVLW 0
000190 223D           00498     ADDWFC Delta_Error_H, F 
                      00499 
000192                00500 FASE_3_MULTIPLICAR_D
                      00501     ; ---------------------------------------------------------------------
                      00502     ; FASE 3: MULTIPLICACIÓN 16x8 BITS (Hardware)
                      00503     ; ---------------------------------------------------------------------
                      00504     
                      00505     ; PASO A: Multiplicar Parte Baja (Delta_Error_L * Kd)
000192 503B           00506     MOVF Kd, W
000194 023C           00507     MULWF Delta_Error_L     
                      00508     
000196 CFF3 F03E      00509     MOVFF PRODL, Termino_D_L ; Guardamos parte baja final
00019A CFF4 F03F      00510     MOVFF PRODH, Termino_D_H ; Guardamos el acarreo en la parte alta
                      00511     
                      00512     ; PASO B: Multiplicar Parte Alta (Delta_Error_H * Kd)
00019E 503B           00513     MOVF Kd, W
0001A0 023D           00514     MULWF Delta_Error_H     
                      00515     
                      00516     ; Sumamos el resultado cruzado a la parte alta
0001A2 50F3           00517     MOVF PRODL, W
0001A4 263F           00518     ADDWF Termino_D_H, F    
