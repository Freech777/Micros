0000EC 2632           00342     ADDWF Suma_Der_L, F
0000EE 50F4           00343     MOVF PRODH, W
0000F0 2233           00344     ADDWFC Suma_Der_H, F
                      00345 
                      00346     ; --- Sensor S6 (Peso 30) ---
