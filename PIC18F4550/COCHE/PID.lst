                      00024 ;   (CCP)               PIN PC2
                      00025 
                      00026 
                      00027 ;============Modulos de logica de los motores avanzar y retroceder=======
                      00028 ;   PIC18F4550       DRIVER TB717     
                      00029 ;   PIN PD0              AIN1
                      00030 ;   PIN PD1              AIN2
                      00031 ;   PIN PD2              BIN1
                      00032 ;   PIN PD3              BIN2
                      00033 ;   PIN PC1              PWMA
