                      00045 ; --- CONFIGURACIÓN DE FUSIBLES (CRÍTICO) ---
                      00046     ; Configuración para cristal externo de 20MHz y núcleo a 48MHz
                      00047     
C4 3E DF FE F9 9B FF F00048     CONFIG PLLDIV = 5         ; Divide el cristal de 20MHz entre 5 (para dar los 4MHz que requiere el PL
                            L)
       F FF FF FF FF 
                      00049     CONFIG CPUDIV = OSC1_PLL2 ; Divide el reloj del PLL (96MHz) entre 2 = 48MHz de velocidad final
