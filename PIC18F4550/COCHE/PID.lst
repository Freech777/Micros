                      00325     ; ==========================================
                      00326     ; CÁLCULO DEL LADO DERECHO (S4 a S7)
                      00327     ; ==========================================
                      00328     
                      00329     ; --- Sensor S4 (Peso 10) ---
0000DA 0E0A           00330     MOVLW .10           ; Cargar el número 10 en decimal (.10) a W
0000DC 022E           00331     MULWF Sens4         ; Multiplicar W * Sens4. Resultado en PRODH:PRODL
                      00332     ; Sumar al acumulador Derecho de 16 bits
0000DE 50F3           00333     MOVF PRODL, W       
0000E0 2632           00334     ADDWF Suma_Der_L, F ; Suma la parte baja
0000E2 50F4           00335     MOVF PRODH, W
0000E4 2233           00336     ADDWFC Suma_Der_H, F; Suma la parte alta CON ACARREO (Carry)
                      00337 
