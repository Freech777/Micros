0000D2                00318 CALCULAR_ERROR
                      00319     ; 1. Limpiar acumuladores antes de sumar
0000D2 6A32           00320     CLRF Suma_Der_L
0000D4 6A33           00321     CLRF Suma_Der_H
0000D6 6A34           00322     CLRF Suma_Izq_L
0000D8 6A35           00323     CLRF Suma_Izq_H
