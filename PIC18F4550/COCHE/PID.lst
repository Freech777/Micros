                      00522 ; =========================================================================
                      00523 ; SUBRUTINA: APLICAR_CONTROL_MOTORES
                      00524 ; Propósito: Suma/Resta el Control (P+D) a la Velocidad_Base, satura los
                      00525 ;            límites a 0-255 y actualiza los registros CCP y el Puerto D.
                      00526 ; =========================================================================
0001A8                00527 APLICAR_CONTROL_MOTORES
                      00528 ; 1. Sumar los términos P y D (Asumiendo que ya están calculados y
                      00529     ;    que la lógica de si se suman o restan entre sí ya se resolvió, 
                      00530     ;    dando un valor final guardado en "Control_L" y "Control_H", y 
                      00531     ;    una bandera final de dirección en "Banderas, 2")
                      00532 
                      00533     ; 2. Cargar la Velocidad Base a las variables temporales
0001A8 5040           00534     MOVF Velocidad_Base, W
0001AA 6E41           00535     MOVWF PWM_Izq_Temp_L
0001AC 6A42           00536     CLRF PWM_Izq_Temp_H      ; Limpiamos parte alta
                      00537     
0001AE 5040           00538     MOVF Velocidad_Base, W
0001B0 6E43           00539     MOVWF PWM_Der_Temp_L
0001B2 6A44           00540     CLRF PWM_Der_Temp_H      ; Limpiamos parte alta
                      00541 
                      00542     ; ---------------------------------------------------------------------
                      00543     ; FASE 3: MEZCLA DE MOTORES (MOTOR MIXING)
                      00544     ; ---------------------------------------------------------------------
                      00545     ; Revisamos la bandera final de dirección (Bit 2: 0=Der, 1=Izq)
0001B4 B438           00546     BTFSC Banderas, 2
0001B6 D009           00547     BRA MEZCLA_GIRA_IZQUIERDA
                      00548 
0001B8                00549 MEZCLA_GIRA_DERECHA
                      00550     ; Gira Derecha -> Motor Izq Acelera, Motor Der Frena
                      00551     ; PWM_Izq = Velocidad_Base + Control
0001B8 5028           00552     MOVF Control_L, W
0001BA 2641           00553     ADDWF PWM_Izq_Temp_L, F
0001BC 5029           00554     MOVF Control_H, W
0001BE 2242           00555     ADDWFC PWM_Izq_Temp_H, F
                      00556 
                      00557     ; PWM_Der = Velocidad_Base - Control
0001C0 5028           00558     MOVF Control_L, W
0001C2 5E43           00559     SUBWF PWM_Der_Temp_L, F
0001C4 5029           00560     MOVF Control_H, W
0001C6 5A44           00561     SUBWFB PWM_Der_Temp_H, F
0001C8 D008           00562     BRA FASE_4_SATURACION
                      00563 
0001CA                00564 MEZCLA_GIRA_IZQUIERDA
                      00565     ; Gira Izquierda -> Motor Izq Frena, Motor Der Acelera
                      00566     ; PWM_Izq = Velocidad_Base - Control
0001CA 5028           00567     MOVF Control_L, W
0001CC 5E41           00568     SUBWF PWM_Izq_Temp_L, F
0001CE 5029           00569     MOVF Control_H, W
0001D0 5A42           00570     SUBWFB PWM_Izq_Temp_H, F
                      00571 
MPASM  5.39                           PID.ASM   5-31-2026  18:34:27         PAGE 12


LOC  OBJECT CODE     LINE SOURCE TEXT
  VALUE

                      00572     ; PWM_Der = Velocidad_Base + Control
0001D2 5028           00573     MOVF Control_L, W
0001D4 2643           00574     ADDWF PWM_Der_Temp_L, F
0001D6 5029           00575     MOVF Control_H, W
0001D8 2244           00576     ADDWFC PWM_Der_Temp_H, F
                      00577 
0001DA                00578 FASE_4_SATURACION
                      00579     ; ---------------------------------------------------------------------
                      00580     ; FASE 4: SATURACIÓN (CLAMPING) PARA PROTEGER EL PWM (0 a 255)
                      00581     ; ---------------------------------------------------------------------
                      00582 
                      00583     ; --- LÍMITE SUPERIOR (Max 255) ---
                      00584     ; Si la parte alta (_H) es mayor a 0, significa que el número es mayor a 255.
                      00585     ; Saturación Motor Izquierdo:
0001DA 5242           00586     MOVF PWM_Izq_Temp_H, F  ; Actualiza la bandera Z
0001DC A4D8           00587     BTFSS STATUS, Z         ; ¿Es cero?
0001DE 6841           00588     SETF PWM_Izq_Temp_L     ; Si no es cero (es >255), fuerza la parte baja a 255 (0xFF)
                      00589 
                      00590     ; Saturación Motor Derecho:
0001E0 5244           00591     MOVF PWM_Der_Temp_H, F
0001E2 A4D8           00592     BTFSS STATUS, Z
0001E4 6843           00593     SETF PWM_Der_Temp_L
                      00594 
                      00595     ; --- LÍMITE INFERIOR (Min 0) ---
                      00596     ; En ensamblador, si restaste y dio negativo, el número se volvió enorme 
                      00597     ; (ej. 0 - 5 = 251 en 8 bits). Pero, en 16 bits, la parte alta (_H) 
                      00598     ; se llena de unos (0xFF). Usaremos esto para detectar números negativos.
                      00599     
                      00600     ; Saturación Inferior Motor Izquierdo:
0001E6 BE42           00601     BTFSC PWM_Izq_Temp_H, 7 ; Revisa el bit de signo de la parte alta
0001E8 6A41           00602     CLRF PWM_Izq_Temp_L     ; Si es 1 (negativo), fuerza la velocidad a 0
                      00603 
                      00604     ; Saturación Inferior Motor Derecho:
0001EA BE44           00605     BTFSC PWM_Der_Temp_H, 7
0001EC 6A43           00606     CLRF PWM_Der_Temp_L
                      00607 
                      00608     ; ---------------------------------------------------------------------
                      00609     ; FASE 5: ESCRITURA EN HARDWARE (EL FINAL DEL CICLO PID)
                      00610     ; ---------------------------------------------------------------------
                      00611     
                      00612     ; 1. Asegurar que ambos motores estén configurados "Hacia Adelante"
                      00613     ; Recordando tu tabla: PD0/PD1 son AIN, PD2/PD3 son BIN.
                      00614     ; Para adelante en el TB6612FNG: IN1=1, IN2=0
0001EE 0E05           00615     MOVLW b'00000101'   ; 0000_0101
0001F0 6E8C           00616     MOVWF LATD          ; Escribe la dirección de giro
                      00617 
                      00618     ; 2. Escribir los valores finales a los registros PWM del PIC
                      00619     ; (CCPR1L controla el pin RC2, CCPR2L controla el pin RC1)
0001F2 5041           00620     MOVF PWM_Izq_Temp_L, W
0001F4 6EBE           00621     MOVWF CCPR1L        ; Actualiza Duty Cycle Motor Izquierdo
                      00622     
0001F6 5043           00623     MOVF PWM_Der_Temp_L, W
0001F8 6EBB           00624     MOVWF CCPR2L        ; Actualiza Duty Cycle Motor Derecho
MPASM  5.39                           PID.ASM   5-31-2026  18:34:27         PAGE 13


