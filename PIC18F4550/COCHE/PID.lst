LOC  OBJECT CODE     LINE SOURCE TEXT
  VALUE

                      00201     ; [Aquí irá una rutina de RESTA de 16 bits]
                      00202 
00005E EC69 F000      00203     CALL CALCULAR_ERROR
                      00204 
                      00205     ; PASO 3: Calcular Término Derivativo (D = Kd * (Error - Error_Anterior))
                      00206     ; [Resta y Multiplicación]
                      00207 
000062 ECB9 F000      00208     CALL CALCULAR_DERIVATIVO
                      00209 
                      00210     ; PASO 4: Calcular Término Proporcional (P = Kp * Error)
                      00211     ; [Aquí irá una rutina de MULTIPLICACIÓN 8x16 bits]
                      00212 
000066 ECA4 F000      00213     CALL CALCULAR_PROPORCIONAL
                      00214 
                      00215     ; PASO 5: Sumar términos de Control = P + D
                      00216     ; [Suma de 16 bits]
00006A ECFE F000      00217     CALL SUMA_PD
                      00218 
                      00219     ; PASO 6: Aplicar el valor de 'Control' a los registros CCPR1L y CCPR2L (PWM)
                      00220     ; Ajustando la lógica de dirección en PORTD (TB6612FNG)
00006E EC1C F001      00221     CALL CONTROL_PWM
                      00222 
                      00223     ; PASO 7: Preparar para el siguiente ciclo
                      00224     ; Mover Error actual a Error_Anterior para la próxima derivada
000072 C024 F026      00225     MOVFF Error_L, Error_Anterior_L
000076 C025 F027      00226     MOVFF Error_H, Error_Anterior_H
                      00227 
                      00228 ; --- FIN DEL CICLO PID ---
                      00229 
                      00230     ; Recargar el Timer0 para mantener el tiempo exacto
                      00231     ; (Valores dependen del tiempo que elijas)
00007A 0E00           00232     MOVLW 0x00      ; Cargar parte alta del Timer
00007C 6ED7           00233     MOVWF TMR0H
00007E 0E00           00234     MOVLW 0x00      ; Cargar parte baja del Timer
000080 6ED6           00235     MOVWF TMR0L
                      00236 
                      00237     ; Limpiar la bandera de interrupción para que pueda volver a ocurrir
000082 94F2           00238     BCF INTCON, TMR0IF
                      00239 
000084                00240 SALIR_INTERRUPCION
000084 0011           00241     RETFIE FAST         ; Retorna de la interrupción restaurando registros vitales
                      00242 
000086                00243 CONFIGURAR_ADC
                      00244     ; --- ADCON1: Configurar pines analógicos ---
                      00245     ; PCFG = 0010: Configura desde AN0 hasta AN12 como analógicos.
                      00246     ; Vref+ y Vref- se conectan internamente a VDD (5V) y VSS (GND).
000086 0E02           00247     MOVLW b'00000010'
000088 6EC1           00248     MOVWF ADCON1
                      00249 
                      00250     ; --- ADCON2: Formato y Tiempos del ADC ---
                      00251     ; Bit 7 (ADFM) = 0 -> Justificado a la Izquierda (Solo leeremos ADRESH)
