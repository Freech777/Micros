0001FC                00629 SUMA_PD
                      00630 ; =========================================================================
                      00631 ; PASO 5: CONSOLIDACIÓN DE TÉRMINOS (Control = P + D)
                      00632 ; =========================================================================
                      00633 ; Se evalúa si P y D empujan en la misma dirección o en direcciones opuestas.
                      00634     
0001FC 5038           00635     MOVF Banderas, W
0001FE 0B03           00636     ANDLW b'00000011'       ; Aislamos los bits de dirección de P (bit 0) y D (bit 1)
000200 0A00           00637     XORLW b'00000000'       ; Comprobamos si ambos son 0 (Dirección Derecha)
000202 E00F           00638     BZ SUMAR_TERMINOS
                      00639     
000204 5038           00640     MOVF Banderas, W
000206 0B03           00641     ANDLW b'00000011'
000208 0A03           00642     XORLW b'00000011'       ; Comprobamos si ambos son 1 (Dirección Izquierda)
00020A E00B           00643     BZ SUMAR_TERMINOS
                      00644 
00020C                00645 RESTAR_TERMINOS
                      00646     ; P y D tienen direcciones opuestas. Se restan (P - D). 
                      00647     ; Se asume que P > D en magnitud para este diseño base.
00020C 503E           00648     MOVF Termino_D_L, W
00020E 5C39           00649     SUBWF Termino_P_L, W
000210 6E28           00650     MOVWF Control_L
                      00651     
000212 503F           00652     MOVF Termino_D_H, W
000214 583A           00653     SUBWFB Termino_P_H, W
000216 6E29           00654     MOVWF Control_H
                      00655     
                      00656     ; La dirección final dominante (Bit 2) será la del término Proporcional
000218 B038           00657     BTFSC Banderas, 0
00021A 8438           00658     BSF Banderas, 2         
00021C A038           00659     BTFSS Banderas, 0
00021E 9438           00660     BCF Banderas, 2         
000220 0012           00661     RETURN
                      00662 
000222                00663 SUMAR_TERMINOS
                      00664     ; P y D van en la misma dirección. Se suman las magnitudes de 16 bits.
000222 503E           00665     MOVF Termino_D_L, W
000224 2439           00666     ADDWF Termino_P_L, W
000226 6E28           00667     MOVWF Control_L
                      00668     
000228 503F           00669     MOVF Termino_D_H, W
00022A 203A           00670     ADDWFC Termino_P_H, W
00022C 6E29           00671     MOVWF Control_H
                      00672     
                      00673     ; La dirección final hereda la dirección compartida
00022E B038           00674     BTFSC Banderas, 0
000230 8438           00675     BSF Banderas, 2
000232 A038           00676     BTFSS Banderas, 0
000234 9438           00677     BCF Banderas, 2
