000040 8CF2           00166     BSF INTCON, PEIE    ; Habilitar interrupciones periféricas
                      00167 
000042                00168 BUCLE_PRINCIPAL
                      00169 
000042 B681           00170     BTFSC PORTB, 3
000044 D7FE           00171     BRA BUCLE_PRINCIPAL
