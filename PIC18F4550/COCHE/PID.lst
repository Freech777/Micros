000298                00764 CONFIGURAR_PWM
                      00765 ; =========================================================================
                      00766 ; SUBRUTINA: CONFIGURAR_PWM
                      00767 ; Propósito: Inicializa Timer2 y los módulos CCP1/CCP2 para generar señales 
                      00768 ;            PWM a 46.8 kHz con resolución de 8 bits.
                      00769 ; =========================================================================
                      00770 ; 1. Configurar los pines físicos como salidas (El paso vital)
                      00771     ; Según tu tabla: RC1 es PWM_Motor_Derecho, RC2 es PWM_Motor_Izquierdo
000298 9294           00772     BCF TRISC, 1        ; Limpiamos el bit 1 de TRISC (RC1 como salida)
00029A 9494           00773     BCF TRISC, 2        ; Limpiamos el bit 2 de TRISC (RC2 como salida)
                      00774 
                      00775     ; 2. Establecer la Frecuencia (El periodo de la señal)
                      00776     ; Cargar 0xFF (255) nos da la resolución de 8 bits exacta para tus cálculos
00029C 0EFF           00777     MOVLW 0xFF
00029E 6ECB           00778     MOVWF PR2
                      00779 
                      00780     ; 3. Inicializar el Duty Cycle a 0 (Seguridad ante todo)
                      00781     ; Esto asegura que el robot no arranque disparado apenas lo enciendes
0002A0 6ABE           00782     CLRF CCPR1L         ; Motor Izquierdo a 0%
0002A2 6ABB           00783     CLRF CCPR2L         ; Motor Derecho a 0%
MPASM  5.39                           PID.ASM   5-31-2026  18:34:27         PAGE 16


LOC  OBJECT CODE     LINE SOURCE TEXT
  VALUE

                      00784 
                      00785     ; 4. Configurar los módulos CCP en modo PWM estándar
                      00786     ; Los bits 3-0 en '1100' encienden la función PWM
                      00787     ; Los bits 5-4 en '00' son los bits menos significativos del Duty Cycle (los ignoramos)
0002A4 0E0C           00788     MOVLW b'00001100'
0002A6 6EBD           00789     MOVWF CCP1CON       
0002A8 6EBA           00790     MOVWF CCP2CON
                      00791 
                      00792     ; 5. Encender el Motor del PWM (Timer2)
                      00793     ; Bit 2 (TMR2ON) = 1 -> Enciende el Timer2
                      00794     ; Bits 1-0 (T2CKPS) = 00 -> Prescaler de 1:1
0002AA 0E04           00795     MOVLW b'00000100'
0002AC 6ECA           00796     MOVWF T2CON
                      00797 
0002AE 0012           00798     RETURN
                      00799 
                      00800 
0002B0                00801 RETARDO_DEBOUNCE
                      00802     ; Retardo simple de aprox 20ms a 48MHz para absorber el ruido mecánico
0002B0 0E64           00803     MOVLW .100
0002B2 6E46           00804     MOVWF contador2
0002B4                00805 L_Debounce2
0002B4 0EFA           00806     MOVLW .250
0002B6 6E45           00807     MOVWF contador1
0002B8                00808 L_Debounce1
0002B8 2E45           00809     DECFSZ contador1, F
0002BA D7FE           00810     BRA L_Debounce1
0002BC 2E46           00811     DECFSZ contador2, F
0002BE D7FA           00812     BRA L_Debounce2
0002C0 0012           00813     RETURN
