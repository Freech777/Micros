0000F6 50F3           00349     MOVF PRODL, W
0000F8 2632           00350     ADDWF Suma_Der_L, F
0000FA 50F4           00351     MOVF PRODH, W
0000FC 2233           00352     ADDWFC Suma_Der_H, F
                      00353 
