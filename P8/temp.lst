                      00001 ; ==============================================================================
                      00002 ;  BARRIDO DE LEDs CON REINICIO CONDICIONAL
                      00003 ;  Microcontrolador: PIC16F877A
                      00004 ;  Oscilador: 4 MHz (1 instrucción = 1 microsegundo)
                      00005 ; ==============================================================================
                      00006 ;  ENTRADAS  (PORTB)
                      00007 ;    RB0 = Botón de INICIO (PB1) - Activo en ALTO (1)
                      00008 ;    RB1 = Botón de PARO   (PB2) - Activo en ALTO (1)
                      00009 ;
                      00010 ;  SALIDAS   (PORTC)
                      00011 ;    RC0 a RC7 = LEDs indicadores
                      00012 ; ==============================================================================
                      00013 
                      00014     LIST        P=16F877A
                      00015     #INCLUDE    <P16F877A.INC>
                      00001         LIST
                      00002 
                      00003 ;==========================================================================
                      00004 ;  MPASM PIC16F877A processor include
                      00005 ; 
                      00006 ;  (c) Copyright 1999-2010 Microchip Technology, All rights reserved
                      00007 ;==========================================================================
                      00008 
                      00555         LIST
                      00016 
2007   3F31           00017     __CONFIG    _XT_OSC & _WDT_OFF & _PWRTE_ON & _BODEN_OFF & _LVP_OFF & _CP_OFF
                      00018 
                      00019     CBLOCK  0x20
  00000020            00020         LED_STATE   ; Guarda la posición actual del LED encendido
  00000021            00021         CONT1       ; Variables para el retardo
  00000022            00022         CONT2
  00000023            00023         CONT3
                      00024     ENDC
                      00025 
0000                  00026     ORG     0x0000
0000   2801           00027     GOTO    INICIO
                      00028 
                      00029 ; ==============================================================================
                      00030 ;  CONFIGURACIÓN INICIAL
                      00031 ; ==============================================================================
0001                  00032 INICIO:
0001   1683           00033     BSF     STATUS, RP0     ; Banco 1
Message[302]: Register in operand not in bank 0.  Ensure that bank bits are correct.
0002   0187           00034     CLRF    TRISC           ; PORTC como salida (LEDs)
0003   30FF           00035     MOVLW   0xFF
Message[302]: Register in operand not in bank 0.  Ensure that bank bits are correct.
0004   0086           00036     MOVWF   TRISB           ; PORTB como entrada (Botones)
0005   1283           00037     BCF     STATUS, RP0     ; Banco 0
                      00038 
0006   0187           00039     CLRF    PORTC           ; Apagar todos los LEDs
                      00040     
                      00041     ; La primera vez iniciamos el barrido desde RC0
0007   3001           00042     MOVLW   b'00000001'     
MPASM  5.39                          TEMP.ASM   5-19-2026  22:55:53         PAGE  2


LOC  OBJECT CODE     LINE SOURCE TEXT
  VALUE

0008   00A0           00043     MOVWF   LED_STATE
                      00044 
                      00045 ; ==============================================================================
                      00046 ;  ESTADO DE REPOSO (ESPERANDO RB0)
                      00047 ; ==============================================================================
0009                  00048 ESPERAR_INICIO:
0009   1886           00049     BTFSC   PORTB, 1        ; Por seguridad, si presionan RB1, asegurar apagado
000A   281E           00050     GOTO    DETENER
                      00051 
000B   1C06           00052     BTFSS   PORTB, 0        ; ¿Se presionó RB0? (Espera un 1 lógico)
000C   2809           00053     GOTO    ESPERAR_INICIO  ; Si no, sigue esperando
                      00054 
                      00055     ; Si se presionó RB0, esperamos a que lo suelten para evitar dobles lecturas
000D                  00056 ESPERAR_SOLTAR_RB0:
000D   1806           00057     BTFSC   PORTB, 0
000E   280D           00058     GOTO    ESPERAR_SOLTAR_RB0
                      00059 
                      00060 ; ==============================================================================
                      00061 ;  ESTADO DE BARRIDO ACTIVO
                      00062 ; ==============================================================================
000F                  00063 BARRIDO_LOOP:
                      00064     ; 1. Encender el LED correspondiente
000F   0820           00065     MOVF    LED_STATE, W
0010   0087           00066     MOVWF   PORTC
                      00067 
                      00068     ; 2. Esperar 0.5 segundos (mientras vigila si se presiona RB1)
0011   2024           00069     CALL    DELAY_500MS_CHECK_STOP
                      00070 
                      00071     ; 3. Verificar qué devolvió el retardo
                      00072     ; Si W=1 significa que se presionó RB1 durante la pausa
0012   3A01           00073     XORLW   0x01
0013   1903           00074     BTFSC   STATUS, Z
0014   281E           00075     GOTO    DETENER         ; Se interrumpió el ciclo
                      00076 
                      00077     ; 4. Si terminó el medio segundo, desplazar el bit a la izquierda
0015   1003           00078     BCF     STATUS, C       ; Limpiar el Carry por seguridad
0016   0DA0           00079     RLF     LED_STATE, F    ; Desplazar el 1 a la izquierda
                      00080 
                      00081     ; 5. Si el 1 se salió del registro (todos los bits en 0), reiniciar en RC0
0017   0820           00082     MOVF    LED_STATE, W
0018   1903           00083     BTFSC   STATUS, Z
0019   281B           00084     GOTO    REINICIAR_RC0
                      00085     
001A   280F           00086     GOTO    BARRIDO_LOOP    ; Repetir con el siguiente LED
                      00087 
001B                  00088 REINICIAR_RC0:
001B   3001           00089     MOVLW   b'00000001'     ; Vuelve a iniciar en RC0 de forma natural
001C   00A0           00090     MOVWF   LED_STATE
001D   280F           00091     GOTO    BARRIDO_LOOP
                      00092 
                      00093 ; ==============================================================================
                      00094 ;  RUTINA DE PARO Y RESET (Condición de RC3)
                      00095 ; ==============================================================================
MPASM  5.39                          TEMP.ASM   5-19-2026  22:55:53         PAGE  3


LOC  OBJECT CODE     LINE SOURCE TEXT
  VALUE

001E                  00096 DETENER:
001E   0187           00097     CLRF    PORTC           ; Apagar todos los LEDs al instante
                      00098     
                      00099     ; Configurar para que la próxima vez inicie en RC3 (Bit 3)
001F   3008           00100     MOVLW   b'00001000'     
0020   00A0           00101     MOVWF   LED_STATE
                      00102 
0021                  00103 ESPERAR_SOLTAR_RB1:
0021   1886           00104     BTFSC   PORTB, 1        ; Esperar hasta que se suelte el botón de paro
0022   2821           00105     GOTO    ESPERAR_SOLTAR_RB1
                      00106     
0023   2809           00107     GOTO    ESPERAR_INICIO  ; Volver a esperar RB0
                      00108 
                      00109 ; ==============================================================================
                      00110 ;  SUBRUTINA: Retardo de ~0.5 segundos vigilando RB1
                      00111 ;  Retorna W = 0 si terminó normal. Retorna W = 1 si se presionó RB1.
                      00112 ; ==============================================================================
0024                  00113 DELAY_500MS_CHECK_STOP:
0024   3032           00114     MOVLW   .50             ; 50 ciclos externos
0025   00A3           00115     MOVWF   CONT3
0026                  00116 LOOP_500:
                      00117     
                      00118     ; --- AQUÍ REVISAMOS EL BOTÓN DURANTE EL RETARDO ---
0026   1886           00119     BTFSC   PORTB, 1        ; ¿Se presionó RB1 (Paro)?
0027   3401           00120     RETLW   0x01            ; Si sí, salir inmediatamente con W=1
                      00121     ; --------------------------------------------------
                      00122 
0028   3028           00123     MOVLW   .40             ; Ciclo medio
0029   00A2           00124     MOVWF   CONT2
002A                  00125 LOOP_10:
002A   3052           00126     MOVLW   .82             ; Ciclo interno
002B   00A1           00127     MOVWF   CONT1
002C                  00128 LOOP_1:
002C   0000           00129     NOP
002D   0BA1           00130     DECFSZ  CONT1, F
002E   282C           00131     GOTO    LOOP_1
                      00132     
002F   0BA2           00133     DECFSZ  CONT2, F
0030   282A           00134     GOTO    LOOP_10
                      00135 
0031   0BA3           00136     DECFSZ  CONT3, F
0032   2826           00137     GOTO    LOOP_500
                      00138 
0033   3400           00139     RETLW   0x00            ; Retornar W=0 (Ciclo completado sin interrupciones)
                      00140 
                      00141     END
