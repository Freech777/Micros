                      00357 #include "Retardos.inc"
                      00001 ;**************************** Librería "RETARDOS.INC" *********************************
                      00002 ;
                      00003 ;       ===================================================================
                      00004 ;         Del libro "MICROCONTROLADOR PIC16F84. DESARROLLO DE PROYECTOS"
                      00005 ;         E. Palacios, F. Remiro y L. López.            www.pic16f84a.com
                      00006 ;         Editorial Ra-Ma.  www.ra-ma.es
                      00007 ;       ===================================================================
                      00008 ;
                      00009 ; Librería con múltiples subrutinas de retardos, desde 4 microsegundos hasta 20 segundos. 
                      00010 ; Además se pueden implementar otras subrutinas muy fácilmente.
                      00011 ;
                      00012 ; Se han calculado para un sistema microcontrolador con un PIC trabajando con un cristal
                      00013 ; de cuarzo a 4 MHz. Como cada ciclo máquina son 4 ciclos de reloj, resulta que cada
                      00014 ; ciclo máquina tarda 4 x 1/4MHz = 1 µs.
                      00015 ;
                      00016 ; En los comentarios, "cm" significa "ciclos máquina".
                      00017 ;
                      00018 ; ZONA DE DATOS *********************************************************************
                      00019 
                      00020         CBLOCK
  0000002B            00021         R_ContA                                         ; Contadores para los retardos.
  0000002C            00022         R_ContB
  0000002D            00023         R_ContC
                      00024         ENDC
                      00025 ;
                      00026 ; RETARDOS de 4 hasta 10 microsegundos ---------------------------------------------------
                      00027 ;
                      00028 ; A continuación retardos pequeńos teniendo en cuenta que para una frecuencia de 4 MHZ,
                      00029 ; la llamada a subrutina "call" tarda 2 ciclos máquina, el retorno de subrutina
                      00030 ; "return" toma otros 2 ciclos máquina y cada instrucción "nop" tarda 1 ciclo máquina.
                      00031 ;
00D0                  00032 Retardo_10micros                                ; La llamada "call" aporta 2 ciclos máquina.
00D0   0000           00033         nop                                                     ; Aporta 1 ciclo máquina.
00D1   0000           00034         nop                                                     ; Aporta 1 ciclo máquina.
MPASM  5.39                           JOY.ASM   5-22-2026  3:16:32         PAGE  9


LOC  OBJECT CODE     LINE SOURCE TEXT
  VALUE

00D2   0000           00035         nop                                                     ; Aporta 1 ciclo máquina.
00D3   0000           00036         nop                                                     ; Aporta 1 ciclo máquina.
00D4   0000           00037         nop                                                     ; Aporta 1 ciclo máquina.
00D5                  00038 Retardo_5micros                                 ; La llamada "call" aporta 2 ciclos máquina.
00D5   0000           00039         nop                                                     ; Aporta 1 ciclo máquina.
00D6                  00040 Retardo_4micros                                 ; La llamada "call" aporta 2 ciclos máquina.
00D6   0008           00041         return                                          ; El salto del retorno aporta 2 ciclos máquina.
                      00042 ;
                      00043 ; RETARDOS de 20 hasta 500 microsegundos ------------------------------------------------
                      00044 ;
00D7                  00045 Retardo_500micros                               ; La llamada "call" aporta 2 ciclos máquina.
00D7   0000           00046         nop                                                     ; Aporta 1 ciclo máquina.
00D8   30A4           00047         movlw   d'164'                          ; Aporta 1 ciclo máquina. Este es el valor de "K".
00D9   28E3           00048         goto    RetardoMicros           ; Aporta 2 ciclos máquina.
00DA                  00049 Retardo_200micros                               ; La llamada "call" aporta 2 ciclos máquina.
00DA   0000           00050         nop                                                     ; Aporta 1 ciclo máquina.
00DB   3040           00051         movlw   d'64'                           ; Aporta 1 ciclo máquina. Este es el valor de "K".
00DC   28E3           00052         goto    RetardoMicros           ; Aporta 2 ciclos máquina.
00DD                  00053 Retardo_100micros                               ; La llamada "call" aporta 2 ciclos máquina.
00DD   301F           00054         movlw   d'31'                           ; Aporta 1 ciclo máquina. Este es el valor de "K".
00DE   28E3           00055         goto    RetardoMicros           ; Aporta 2 ciclos máquina.
00DF                  00056 Retardo_50micros                                ; La llamada "call" aporta 2 ciclos máquina.
00DF   0000           00057         nop                                                     ; Aporta 1 ciclo máquina.
00E0   300E           00058         movlw   d'14'                           ; Aporta 1 ciclo máquina. Este es el valor de "K".
00E1   28E3           00059         goto    RetardoMicros           ; Aporta 2 ciclos máquina.
00E2                  00060 Retardo_20micros                                ; La llamada "call" aporta 2 ciclos máquina.
00E2   3005           00061         movlw   d'5'                            ; Aporta 1 ciclo máquina. Este es el valor de "K".
                      00062 ;
                      00063 ; El próximo bloque "RetardoMicros" tarda:
                      00064 ; 1 + (K-1) + 2 + (K-1)x2 + 2 = (2 + 3K) ciclos máquina.
                      00065 ;
00E3                  00066 RetardoMicros
00E3   00AB           00067         movwf   R_ContA                         ; Aporta 1 ciclo máquina.
00E4                  00068 Rmicros_Bucle
00E4   0BAB           00069         decfsz  R_ContA,F                       ; (K-1)x1 cm (cuando no salta) + 2 cm (al saltar).
00E5   28E4           00070         goto    Rmicros_Bucle           ; Aporta (K-1)x2 ciclos máquina.
00E6   0008           00071         return                                          ; El salto del retorno aporta 2 ciclos máquina.
                      00072 ;
                      00073 ;En total estas subrutinas tardan:
                      00074 ; - Retardo_500micros:  2 + 1 + 1 + 2 + (2 + 3K) = 500 cm = 500 µs. (para K=164 y 4 MHz).
                      00075 ; - Retardo_200micros:  2 + 1 + 1 + 2 + (2 + 3K) = 200 cm = 200 µs. (para K= 64 y 4 MHz).
                      00076 ; - Retardo_100micros:  2     + 1 + 2 + (2 + 3K) = 100 cm = 100 µs. (para K= 31 y 4 MHz).
                      00077 ; - Retardo_50micros :  2 + 1 + 1 + 2 + (2 + 3K) =  50 cm =  50 µs. (para K= 14 y 4 MHz).
                      00078 ; - Retardo_20micros :  2     + 1     + (2 + 3K) =  20 cm =  20 µs. (para K=  5 y 4 MHz).
                      00079 ;
                      00080 ; RETARDOS de 1 ms hasta 200 ms. --------------------------------------------------------
                      00081 ;
