                      00310 ; -----------------------------------------------------------------
                      00311 ; NUEVA RUTINA: UPDATE_595
                      00312 ; Esta rutina toma las variables LEDS_X y LEDS_Y y las envia en serie
                      00313 ; a los registros de desplazamiento.
                      00314 ; Orden de envio: Primero sale LEDS_Y (terminara en el segundo 74HC595)
                      00315 ;                 Luego sale LEDS_X (se quedara en el primer 74HC595)
                      00316 ; -----------------------------------------------------------------
00BB                  00317 UPDATE_595
00BB   1107           00318     BCF PORTC, 2        ; Pin RC2 (LATCH) en Bajo
                      00319 
                      00320     ; Hacemos copias de los registros para no destruir los originales al rotar
00BC   0826           00321     MOVF LEDS_X, W
00BD   00A9           00322     MOVWF TEMP_X
00BE   0827           00323     MOVF LEDS_Y, W
00BF   00AA           00324     MOVWF TEMP_Y
                      00325 
00C0   3010           00326     MOVLW d'16'         ; Vamos a desplazar 16 bits
00C1   00A8           00327     MOVWF SHIFT_COUNT
                      00328 
00C2   1003           00329     BCF STATUS, C       ; Limpiar carry para evitar basura en el primer bit
                      00330 
00C3                  00331 SHIFT_LOOP
                      00332     ; Desplazamos TEMP_X a la izquierda (El bit 7 de X pasa al Carry)
00C3   0DA9           00333     RLF TEMP_X, F       
                      00334     
                      00335     ; Desplazamos TEMP_Y a la izquierda 
                      00336     ; (El bit 7 de Y pasa al Carry, y el bit 7 de X que estaba en Carry entra al bit 0 de Y)
00C4   0DAA           00337     RLF TEMP_Y, F       
                      00338 
                      00339     ; Verificamos que quedo en el Carry (El MSB de Y) y lo sacamos por DATA (RC0)
MPASM  5.39                           JOY.ASM   5-22-2026  3:16:32         PAGE  8


LOC  OBJECT CODE     LINE SOURCE TEXT
  VALUE

00C5   1C03           00340     BTFSS STATUS, C     
00C6   1007           00341     BCF PORTC, 0        ; Si Carry es 0, pon DATA en 0
00C7   1803           00342     BTFSC STATUS, C     
00C8   1407           00343     BSF PORTC, 0        ; Si Carry es 1, pon DATA en 1
                      00344 
                      00345     ; Damos un pulso al CLOCK (RC1) para que el 595 lea el DATA
00C9   1487           00346     BSF PORTC, 1        
00CA   0000           00347     NOP
00CB   1087           00348     BCF PORTC, 1        
                      00349 
00CC   0BA8           00350     DECFSZ SHIFT_COUNT, F
00CD   28C3           00351     GOTO SHIFT_LOOP
                      00352 
                      00353     ; Una vez enviados los 16 bits, subimos el LATCH para actualizar los LEDs visualmente
00CE   1507           00354     BSF PORTC, 2        
