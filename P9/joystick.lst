LOC  OBJECT CODE     LINE SOURCE TEXT
  VALUE

                      00005 ;         E. Palacios, F. Remiro y L. López.            www.pic16f84a.com
                      00006 ;         Editorial Ra-Ma.  www.ra-ma.es
                      00007 ;       ===================================================================
                      00008 ;
                      00009 ; Librería con múltiples subrutinas de retardos, desde 4 microsegundos hasta 20 segundos. 
                      00010 ; Además se pueden implementar otras subrutinas muy fácilmente.
                      00011 ;
                      00012 ; Se han calculado para un sistema microcontrolador con un PIC trabajando con un cristal
                      00013 ; de cuarzo a 4 MHz. Como cada ciclo máquina son 4 ciclos de reloj, resulta que cada
                      00014 ; ciclo máquina tarda 4 x 1/4MHz = 1 µs.
                      00015 ;
                      00016 ; En los comentarios, "cm" significa "ciclos máquina".
                      00017 ;
                      00018 ; ZONA DE DATOS *********************************************************************
                      00019 
                      00020         CBLOCK
  00000026            00021         R_ContA                                         ; Contadores para los retardos.
  00000027            00022         R_ContB
  00000028            00023         R_ContC
                      00024         ENDC
                      00025 ;
                      00026 ; RETARDOS de 4 hasta 10 microsegundos ---------------------------------------------------
                      00027 ;
                      00028 ; A continuación retardos pequeńos teniendo en cuenta que para una frecuencia de 4 MHZ,
                      00029 ; la llamada a subrutina "call" tarda 2 ciclos máquina, el retorno de subrutina
                      00030 ; "return" toma otros 2 ciclos máquina y cada instrucción "nop" tarda 1 ciclo máquina.
                      00031 ;
00A9                  00032 Retardo_10micros                                ; La llamada "call" aporta 2 ciclos máquina.
00A9   0000           00033         nop                                                     ; Aporta 1 ciclo máquina.
00AA   0000           00034         nop                                                     ; Aporta 1 ciclo máquina.
00AB   0000           00035         nop                                                     ; Aporta 1 ciclo máquina.
00AC   0000           00036         nop                                                     ; Aporta 1 ciclo máquina.
00AD   0000           00037         nop                                                     ; Aporta 1 ciclo máquina.
00AE                  00038 Retardo_5micros                                 ; La llamada "call" aporta 2 ciclos máquina.
00AE   0000           00039         nop                                                     ; Aporta 1 ciclo máquina.
00AF                  00040 Retardo_4micros                                 ; La llamada "call" aporta 2 ciclos máquina.
00AF   0008           00041         return                                          ; El salto del retorno aporta 2 ciclos máquina.
                      00042 ;
                      00043 ; RETARDOS de 20 hasta 500 microsegundos ------------------------------------------------
                      00044 ;
00B0                  00045 Retardo_500micros                               ; La llamada "call" aporta 2 ciclos máquina.
00B0   0000           00046         nop                                                     ; Aporta 1 ciclo máquina.
00B1   30A4           00047         movlw   d'164'                          ; Aporta 1 ciclo máquina. Este es el valor de "K".
00B2   28BC           00048         goto    RetardoMicros           ; Aporta 2 ciclos máquina.
00B3                  00049 Retardo_200micros                               ; La llamada "call" aporta 2 ciclos máquina.
00B3   0000           00050         nop                                                     ; Aporta 1 ciclo máquina.
00B4   3040           00051         movlw   d'64'                           ; Aporta 1 ciclo máquina. Este es el valor de "K".
00B5   28BC           00052         goto    RetardoMicros           ; Aporta 2 ciclos máquina.
00B6                  00053 Retardo_100micros                               ; La llamada "call" aporta 2 ciclos máquina.
00B6   301F           00054         movlw   d'31'                           ; Aporta 1 ciclo máquina. Este es el valor de "K".
00B7   28BC           00055         goto    RetardoMicros           ; Aporta 2 ciclos máquina.
00B8                  00056 Retardo_50micros                                ; La llamada "call" aporta 2 ciclos máquina.
00B8   0000           00057         nop                                                     ; Aporta 1 ciclo máquina.
MPASM  5.39                      JOYSTICK.ASM   5-17-2026  23:22:54         PAGE  9


LOC  OBJECT CODE     LINE SOURCE TEXT
  VALUE

00B9   300E           00058         movlw   d'14'                           ; Aporta 1 ciclo máquina. Este es el valor de "K".
00BA   28BC           00059         goto    RetardoMicros           ; Aporta 2 ciclos máquina.
00BB                  00060 Retardo_20micros                                ; La llamada "call" aporta 2 ciclos máquina.
00BB   3005           00061         movlw   d'5'                            ; Aporta 1 ciclo máquina. Este es el valor de "K".
                      00062 ;
                      00063 ; El próximo bloque "RetardoMicros" tarda:
                      00064 ; 1 + (K-1) + 2 + (K-1)x2 + 2 = (2 + 3K) ciclos máquina.
                      00065 ;
00BC                  00066 RetardoMicros
00BC   00A6           00067         movwf   R_ContA                         ; Aporta 1 ciclo máquina.
00BD                  00068 Rmicros_Bucle
00BD   0BA6           00069         decfsz  R_ContA,F                       ; (K-1)x1 cm (cuando no salta) + 2 cm (al saltar).
00BE   28BD           00070         goto    Rmicros_Bucle           ; Aporta (K-1)x2 ciclos máquina.
00BF   0008           00071         return                                          ; El salto del retorno aporta 2 ciclos máquina.
                      00072 ;
                      00073 ;En total estas subrutinas tardan:
                      00074 ; - Retardo_500micros:  2 + 1 + 1 + 2 + (2 + 3K) = 500 cm = 500 µs. (para K=164 y 4 MHz).
                      00075 ; - Retardo_200micros:  2 + 1 + 1 + 2 + (2 + 3K) = 200 cm = 200 µs. (para K= 64 y 4 MHz).
                      00076 ; - Retardo_100micros:  2     + 1 + 2 + (2 + 3K) = 100 cm = 100 µs. (para K= 31 y 4 MHz).
                      00077 ; - Retardo_50micros :  2 + 1 + 1 + 2 + (2 + 3K) =  50 cm =  50 µs. (para K= 14 y 4 MHz).
                      00078 ; - Retardo_20micros :  2     + 1     + (2 + 3K) =  20 cm =  20 µs. (para K=  5 y 4 MHz).
                      00079 ;
                      00080 ; RETARDOS de 1 ms hasta 200 ms. --------------------------------------------------------
                      00081 ;
00C0                  00082 Retardo_200ms                                   ; La llamada "call" aporta 2 ciclos máquina.
00C0   30C8           00083         movlw   d'200'                          ; Aporta 1 ciclo máquina. Este es el valor de "M".
00C1   28CF           00084         goto    Retardos_ms                     ; Aporta 2 ciclos máquina.
00C2                  00085 Retardo_100ms                                   ; La llamada "call" aporta 2 ciclos máquina.
00C2   3064           00086         movlw   d'100'                          ; Aporta 1 ciclo máquina. Este es el valor de "M".
00C3   28CF           00087         goto    Retardos_ms                     ; Aporta 2 ciclos máquina.
00C4                  00088 Retardo_50ms                                    ; La llamada "call" aporta 2 ciclos máquina.
00C4   3032           00089         movlw   d'50'                           ; Aporta 1 ciclo máquina. Este es el valor de "M".
00C5   28CF           00090         goto    Retardos_ms                     ; Aporta 2 ciclos máquina.
00C6                  00091 Retardo_20ms                                    ; La llamada "call" aporta 2 ciclos máquina.
00C6   3014           00092         movlw   d'20'                           ; Aporta 1 ciclo máquina. Este es el valor de "M".
00C7   28CF           00093         goto    Retardos_ms                     ; Aporta 2 ciclos máquina.
00C8                  00094 Retardo_10ms                                    ; La llamada "call" aporta 2 ciclos máquina.
00C8   300A           00095         movlw   d'10'                           ; Aporta 1 ciclo máquina. Este es el valor de "M".
