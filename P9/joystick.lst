                      00025 ;
                      00026 ; RETARDOS de 4 hasta 10 microsegundos ---------------------------------------------------
                      00027 ;
                      00028 ; A continuación retardos pequeńos teniendo en cuenta que para una frecuencia de 4 MHZ,
                      00029 ; la llamada a subrutina "call" tarda 2 ciclos máquina, el retorno de subrutina
                      00030 ; "return" toma otros 2 ciclos máquina y cada instrucción "nop" tarda 1 ciclo máquina.
                      00031 ;
0056                  00032 Retardo_10micros                                ; La llamada "call" aporta 2 ciclos máquina.
0056   0000           00033         nop                                                     ; Aporta 1 ciclo máquina.
0057   0000           00034         nop                                                     ; Aporta 1 ciclo máquina.
0058   0000           00035         nop                                                     ; Aporta 1 ciclo máquina.
0059   0000           00036         nop                                                     ; Aporta 1 ciclo máquina.
005A   0000           00037         nop                                                     ; Aporta 1 ciclo máquina.
005B                  00038 Retardo_5micros                                 ; La llamada "call" aporta 2 ciclos máquina.
005B   0000           00039         nop                                                     ; Aporta 1 ciclo máquina.
005C                  00040 Retardo_4micros                                 ; La llamada "call" aporta 2 ciclos máquina.
005C   0008           00041         return                                          ; El salto del retorno aporta 2 ciclos máquina.
                      00042 ;
                      00043 ; RETARDOS de 20 hasta 500 microsegundos ------------------------------------------------
                      00044 ;
005D                  00045 Retardo_500micros                               ; La llamada "call" aporta 2 ciclos máquina.
005D   0000           00046         nop                                                     ; Aporta 1 ciclo máquina.
005E   30A4           00047         movlw   d'164'                          ; Aporta 1 ciclo máquina. Este es el valor de "K".
005F   2869           00048         goto    RetardoMicros           ; Aporta 2 ciclos máquina.
0060                  00049 Retardo_200micros                               ; La llamada "call" aporta 2 ciclos máquina.
0060   0000           00050         nop                                                     ; Aporta 1 ciclo máquina.
0061   3040           00051         movlw   d'64'                           ; Aporta 1 ciclo máquina. Este es el valor de "K".
0062   2869           00052         goto    RetardoMicros           ; Aporta 2 ciclos máquina.
0063                  00053 Retardo_100micros                               ; La llamada "call" aporta 2 ciclos máquina.
0063   301F           00054         movlw   d'31'                           ; Aporta 1 ciclo máquina. Este es el valor de "K".
0064   2869           00055         goto    RetardoMicros           ; Aporta 2 ciclos máquina.
0065                  00056 Retardo_50micros                                ; La llamada "call" aporta 2 ciclos máquina.
0065   0000           00057         nop                                                     ; Aporta 1 ciclo máquina.
0066   300E           00058         movlw   d'14'                           ; Aporta 1 ciclo máquina. Este es el valor de "K".
0067   2869           00059         goto    RetardoMicros           ; Aporta 2 ciclos máquina.
0068                  00060 Retardo_20micros                                ; La llamada "call" aporta 2 ciclos máquina.
0068   3005           00061         movlw   d'5'                            ; Aporta 1 ciclo máquina. Este es el valor de "K".
                      00062 ;
                      00063 ; El próximo bloque "RetardoMicros" tarda:
                      00064 ; 1 + (K-1) + 2 + (K-1)x2 + 2 = (2 + 3K) ciclos máquina.
                      00065 ;
0069                  00066 RetardoMicros
0069   00A2           00067         movwf   R_ContA                         ; Aporta 1 ciclo máquina.
006A                  00068 Rmicros_Bucle
006A   0BA2           00069         decfsz  R_ContA,F                       ; (K-1)x1 cm (cuando no salta) + 2 cm (al saltar).
006B   286A           00070         goto    Rmicros_Bucle           ; Aporta (K-1)x2 ciclos máquina.
006C   0008           00071         return                                          ; El salto del retorno aporta 2 ciclos máquina.
                      00072 ;
                      00073 ;En total estas subrutinas tardan:
                      00074 ; - Retardo_500micros:  2 + 1 + 1 + 2 + (2 + 3K) = 500 cm = 500 µs. (para K=164 y 4 MHz).
                      00075 ; - Retardo_200micros:  2 + 1 + 1 + 2 + (2 + 3K) = 200 cm = 200 µs. (para K= 64 y 4 MHz).
                      00076 ; - Retardo_100micros:  2     + 1 + 2 + (2 + 3K) = 100 cm = 100 µs. (para K= 31 y 4 MHz).
MPASM  5.39                      JOYSTICK.ASM   5-25-2026  4:17:11         PAGE  6


