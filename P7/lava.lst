0034   2810           00126     GOTO    MAIN_LOOP
                      00127 
0035                  00128 AGUA_DRENADA:
0035   3002           00129     MOVLW   LISTA_SECAR
0036   00A0           00130     MOVWF   ESTADO
0037   2810           00131     GOTO    MAIN_LOOP
                      00132 
                      00133 ; ==============================================================================
                      00134 ;  ESTADO 2: LISTA PARA SECAR
                      00135 ;  Motores apagados. LED Lista activo.
                      00136 ;  - Si RA0 (SPA) en ALTO -> esperar en bucle interno hasta que se cierre
                      00137 ;  - Cuando RA0 baja -> retardo de 5 segundos -> pasar a SECANDO
                      00138 ; ==============================================================================
                      00139 ; ==============================================================================
0038                  00140 ESTADO_LISTA_SECAR:
0038   3010           00141     MOVLW   b'00010000'
0039   0086           00142     MOVWF   PORTB
                      00143 
                      00144     ; Comprobar si la puerta está abierta
003A   1805           00145     BTFSC   SPA             ; Si SPA=1 (Puerta abierta)
003B   2810           00146     GOTO    MAIN_LOOP       ; Regresa al bucle principal, manteniéndose en LISTA_SECAR
MPASM  5.39                          LAVA.ASM   5-19-2026  21:59:19         PAGE  4


LOC  OBJECT CODE     LINE SOURCE TEXT
  VALUE

                      00147 
                      00148     ; Si la puerta está cerrada, aplicamos el retardo
003C   2057           00149     CALL    RETARDO_5SEG
                      00150 
                      00151     ; VERIFICACIÓN EXTRA: 
                      00152     ; ¿Se abrió la puerta DURANTE los 5 segundos de espera?
003D   1805           00153     BTFSC   SPA             ; Si SPA=1 ahora
003E   2810           00154     GOTO    MAIN_LOOP       ; Aborta la transición y se mantiene en LISTA_SECAR
                      00155 
                      00156     ; Si la puerta sigue cerrada, pasamos a SECANDO
003F   3003           00157     MOVLW   SECANDO
0040   00A0           00158     MOVWF   ESTADO
0041   2810           00159     GOTO    MAIN_LOOP
                      00160 
                      00161     ; Bucle interno: esperar a que la puerta se cierre (SPA=0)
0042                  00162 ESPERAR_PUERTA:
0042   1805           00163     BTFSC   SPA             ; Si puerta ABIERTA -> seguir esperando aqui mismo
0043   2842           00164     GOTO    ESPERAR_PUERTA
                      00165 
                      00166     ; Puerta cerrada -> retardo de 5 segundos
0044   2057           00167     CALL    RETARDO_5SEG
                      00168 
                      00169     ; Pasar a SECANDO
0045   3003           00170     MOVLW   SECANDO
0046   00A0           00171     MOVWF   ESTADO
0047   2810           00172     GOTO    MAIN_LOOP
                      00173 
                      00174 ; ==============================================================================
