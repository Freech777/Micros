                      00094 ; ==============================================================================
                      00095 ;  ESTADO 0: REPOSO
                      00096 ;  Transición → LAVANDO si: SPA=0 y SNA=1
                      00097 ; ==============================================================================
0025                  00098 ESTADO_REPOSO:
0025   3004           00099     MOVLW   b'00000100'
0026   0086           00100     MOVWF   PORTB
                      00101 
0027   1805           00102     BTFSC   SPA
0028   2810           00103     GOTO    MAIN_LOOP
                      00104 
0029   1C85           00105     BTFSS   SNA
002A   2810           00106     GOTO    MAIN_LOOP
                      00107 
002B   3001           00108     MOVLW   LAVANDO
002C   00A0           00109     MOVWF   ESTADO
002D   2810           00110     GOTO    MAIN_LOOP
                      00111 
                      00112 ;  ESTADO 1: LAVANDO
                      00113 ;  ML encendido. LED Lavando activo.
                      00114 ;  Transición LISTA_SECAR si: SNA=0
                      00115 ;  Fallo si: SPA=1 durante el ciclo
002E                  00116 ESTADO_LAVANDO:
002E   3009           00117     MOVLW   b'00001001'
002F   0086           00118     MOVWF   PORTB
                      00119 
                      00120 
0030   1C85           00121     BTFSS   SNA             
0031   2835           00122     GOTO    AGUA_DRENADA
                      00123 
0032   1805           00124     BTFSC   SPA             
